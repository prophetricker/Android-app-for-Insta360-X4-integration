OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
# Optional OpenAI-compatible proxy, for example: https://xlabapi.com/v1
OPENAI_BASE_URL=
# Optional proxy unblock header, for example: claude-cli/2.0.76 (external, cli)
OPENAI_USER_AGENT=

# Optional DAP runtime paths. Keep model repos and weights outside Git.
DAP_REPO_DIR=
DAP_WEIGHTS_PATH=
DAP_DEVICE=cuda
DAP_PYTHON=
DAP_DEPTH_SCALE=100
